service cloud.firestore {
  match /databases/{database}/documents {
    // Users: each user can read their own, admins can read all
    match /users/{userId} {
      // Users can create their own profile
      allow create: if request.auth != null && request.auth.uid == userId;

      // Read: owner or admins (handle case where user document doesn't exist yet)
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );

      // Update: owner can update their profile, but only if not changing role to 'admin'
      allow update: if request.auth != null && (
        // owner can update if: they own it AND (role field unchanged OR role not being set to admin)
        (request.auth.uid == userId && 
          (!request.resource.data.keys().hasAny(['role']) || 
           !('role' in request.resource.data) ||
           request.resource.data.role == resource.data.role ||
           request.resource.data.role != 'admin'))
        // OR the special super-admin (by email) can set admin roles or update others
        || (request.auth.token.email == 'info@azcoglobal.com')
      );

      // Delete: only the owner may delete their profile, except the protected super-admin email cannot be deleted
      allow delete: if request.auth != null && request.auth.uid == userId && resource.data.email != 'info@azcoglobal.com';
      
      // Addresses subcollection: users can manage their own saved addresses
      match /addresses/{addressId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Products: public read, only admins can modify
    match /products/{doc} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Slides: public read, only admins can modify
    match /slides/{doc} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Orders: users can create/read their own; only admins can update or delete.
    match /orders/{orderId} {
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.auth.token.email_verified == true;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Carts: each user can read/write their own, admins can read all.
    match /carts/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Test collection for connection testing (admin only)
    match /test/{doc} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Wishlists: each user can read/write their own, admins can read all
    match /wishlists/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Analytics/visitor counter: public read, only allow anonymous create
    match /analytics/{doc} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Coupons: authenticated users can read for validation, only admins can write
    match /coupons/{couponId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Gift Cards: authenticated users can read for validation, only admins can write
    match /giftcards/{giftcardId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Settings: public read, only admins can write
    match /settings/{doc} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Reviews: public read, authenticated users can write their own, admins can moderate
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Notifications (top-level collection): deprecated in favor of nested under users
    match /notifications/{notificationId} {
      allow read, write: if false;
    }

    // Users/{userId}/notifications: users can read their own; admins can write
    match /users/{userId}/notifications/{notifId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Visitor Analytics: public write (anyone can log visits), only admins can read
    match /visitor_analytics/{doc} {
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow create: if true; // Allow anonymous tracking
      allow update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}