NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Data mode: local | firebase
DATA_MODE=local

# Local JSON database folder (created automatically)
LOCAL_DB_DIR=.localdb

# Auth/session settings (local development)
AUTH_SECRET=replace-with-random-string
ADMIN_BOOTSTRAP_PASSWORD=Admin@12345

# Razorpay server-side verification
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Firebase Admin (JSON string or base64 depending on your setup)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
