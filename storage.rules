rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Product images: public read, admin write/delete
    match /products/{imageId} {
      allow read: if true; // Public read for product images
      allow write, delete: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Slide/banner images: public read, admin write/delete
    match /slides/{imageId} {
      allow read: if true; // Public read for slide images
      allow write, delete: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Deny all other paths by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
